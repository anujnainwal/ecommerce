<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">
</head>

<body>
   <%- include('../includes/navigation.ejs') %>

    <main> <% if (errorMessage) { %>
        <div class="login_error_message"><%= errorMessage %></div>
    <% } %>
        <form class="product-form" action="/admin/<% if (editing || hasError) { %>edit-product
            <% } else {%>add-product <% } %>" method="POST" novalidate>
            <div class="form-control">
                <label for="title">Title</label>
                <input type="text" name="title" id="title" class="<%= validationErrors.find(e => e.path === 'title') ? 'invalid' : '' %>" value="<% if (editing || hasError) { %><%=product.title %>
                    <% } %>">
            </div> 
             <div class="form-control">
                <label for="url">Image URL</label>
                <input type="url"   class="<%= validationErrors.find(e => e.path === 'imageURL') ? 'invalid' : '' %>" name="imageURL" id="Image url" value="<% if (editing || hasError) { %><%=product.imageURL %>
                    <% } %>">
            </div>
            <div class="form-control">
                <label for="number">Price</label>
                <input type="number" name="price"  class="<%= validationErrors.find(e => e.path === 'price') ? 'invalid' : '' %>" id="price" step="0.5" value="<% if (editing || hasError) { %><%=product.price %><% } %>" >
            </div>
            <div class="form-control">
                <label for="text">Description</label>
                <textarea type="text" name="description"  class="<%= validationErrors.find(e => e.path === 'description') ? 'invalid' : '' %>" id="description" rows="5" cols="35"><% if (editing || hasError) { %><%=product.description %>
                    <% } %></textarea>
            </div>
            <% if (editing ) { %>  <input type="hidden" name="_csrf" value="<%=csrfToken %>" />
             <input type="hidden" value="<%= product.id %>" name="productID">
            <% } %>
            <input type="hidden" name="_csrf" value="<%=csrfToken %>" />
            <button class="btn" type="submit"><% if (editing ) { %> Update Product
            <% } else {%>Add Product <% } %></button>
            
        </form>
    </main>
<%- include('../includes/end.ejs') %>